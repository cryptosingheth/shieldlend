# Contract addresses — set after deployment
# Run: forge script contracts/script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast
NEXT_PUBLIC_SHIELDED_POOL_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_LENDING_POOL_ADDRESS=0x0000000000000000000000000000000000000000

# zkVerify — seed phrase for proof submission server route (/api/zkverify)
# Get a Volta testnet account at: https://docs.zkverify.io/overview/getting-started/wallets
ZKVERIFY_SEED_PHRASE=word1 word2 word3 ...

# RPC (optional — defaults to public Base Sepolia RPC)
NEXT_PUBLIC_RPC_URL=https://sepolia.base.org
