    function test_collateral_invalidProof_zeroProof() public view {
        uint[2] memory pA = [uint256(1), uint256(2)];
        uint[2][2] memory pB = [[uint256(0), uint256(0)], [uint256(0), uint256(0)]];
        uint[2] memory pC = [uint256(1), uint256(2)];
        uint[2] memory pub = [uint256(0), uint256(0)];

