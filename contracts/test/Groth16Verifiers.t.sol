            0x01632f3a48ffa67024b2a96e6124dcb25bf3754af19196816a1dad22596e8858
        ];
        // Tampered borrowed: 5000 instead of 1000
        uint[2] memory pub = [
            uint256(5000),
            uint256(15000)
        ];

        assertFalse(collateral.verifyProof(pA, pB, pC, pub), "Tampered borrowed amount must fail");
