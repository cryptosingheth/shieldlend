# Copy this to .env.deploy and fill in your values
# Usage: source .env.deploy && forge script contracts/script/Deploy.s.sol --rpc-url $BASE_SEPOLIA_RPC_URL --broadcast --verify

# Your wallet private key with Base Sepolia ETH
# Get Base Sepolia ETH from: https://www.alchemy.com/faucets/base-sepolia
export PRIVATE_KEY=0x...

# Base Sepolia RPC (public — or use your own Alchemy/Infura URL)
export BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification (get at https://basescan.org/myapikey)
export BASESCAN_API_KEY=...

# zkVerify Volta seed phrase (for frontend proof submission)
export ZKVERIFY_SEED_PHRASE="word1 word2 word3 ..."
